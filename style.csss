body {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  color: #111;
  background: #fff;
  line-height: 1.6;
}

.container {
  max-width: 980px;
  margin: 60px auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 48px;
}

.sidebar {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.profile-img {
  width: 220px;
  height: auto;
  border-radius: 4px;
  margin-bottom: 24px;
  object-fit: cover;
}

.links {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.links a,
.content a {
  color: #1a1a1a;
  text-decoration: underline;
}

h1 {
  font-size: 2.2rem;
  font-weight: normal;
  margin-top: 0;
  margin-bottom: 24px;
}

h2 {
  font-size: 1.2rem;
  font-weight: normal;
  margin-top: 36px;
  margin-bottom: 12px;
}

p {
  margin-bottom: 18px;
  font-size: 1.05rem;
}

.paper {
  margin-bottom: 18px;
}

@media (max-width: 700px) {
  .container {
    grid-template-columns: 1fr;
    gap: 24px;
    margin: 30px auto;
  }

  .profile-img {
    width: 180px;
  }
}
